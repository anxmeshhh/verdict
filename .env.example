# Verdict server configuration - copy to .env (setup.sh / setup.ps1 does this
# and fills in HOST_DATA_DIR + a generated API key for you).

# --- required ---------------------------------------------------------------
# Absolute HOST path of this repo's ./data directory (DooD path mapping -
# sandbox containers are launched by the host daemon, which can't see
# container paths). setup writes this automatically.
HOST_DATA_DIR=

# Auth for the API (X-API-Key header). Empty = open (local dev only).
VERDICT_SERVER_API_KEY=

# Postgres password (compose-internal)
POSTGRES_PASSWORD=verdict

# --- LLM provider (pick one path) --------------------------------------------
# Cloud (works everywhere): provider + model + key
VERDICT_PROVIDER=
VERDICT_MODEL=
VERDICT_API_KEY=
# provider=custom only:
VERDICT_BASE_URL=

# Local Ollama instead: host install -> http://host.docker.internal:11434
#                  compose profile  -> http://ollama:11434
VERDICT_OLLAMA_URL=

# --- GitHub webhook path (optional - the GitHub Action needs none of this) ---
# Secret you set on the GitHub webhook (Settings -> Webhooks -> Secret)
VERDICT_GITHUB_WEBHOOK_SECRET=
# Token used to clone private repos + post check runs (PAT or App installation token)
VERDICT_GITHUB_TOKEN=

# --- tuning -------------------------------------------------------------------
# Concurrent jobs = concurrent sandbox containers (MAX_CONCURRENT_SANDBOX_RUNS)
VERDICT_WORKER_CONCURRENCY=2
VERDICT_PORT=8400
